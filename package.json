{
  "name": "worktree-manager",
  "version": "0.1.0",
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "postinstall": "node scripts/fix-pty-perms.mjs",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "dist": "electron-vite build && electron-builder --mac --publish=never",
    "dist:dir": "electron-vite build && electron-builder --mac --dir --publish=never"
  },
  "build": {
    "appId": "com.connerkennedy.worktreemanager",
    "productName": "Worktree Manager",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/node-pty/**"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ],
      "category": "public.app-category.developer-tools"
    }
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^31.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^2.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "chokidar": "^3.6.0",
    "diff": "^5.2.0",
    "node-pty": "^1.0.0",
    "react": "^18.3.0",
    "react-diff-view": "^3.2.0",
    "react-dom": "^18.3.0",
    "refractor": "^4.8.0",
    "simple-git": "^3.25.0",
    "zustand": "^4.5.0"
  }
}
